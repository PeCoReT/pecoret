{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base",
    "group:allNonMajor"
  ],
  "rebaseStalePrs": true,
  "packageRules": [
    {
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "automerge": false,
      "automergeType": "pr",
      "platformAutomerge": false,
      "groupName": "all non-major dependencies",
      "groupSlug": "all-minor-patch-deps",
      "matchPackagePatterns": [
        "*"
      ]
    },
    {
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false,
      "groupName": "major dependencies",
      "groupSlug": "major-deps",
      "matchPackageNames": [
        "*"
      ],
      "stabilityDays": 3
    }
  ]
}